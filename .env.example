# Supabase Postgres — authoritative transactional state
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# HydraDB — long-term memory / episodic recall
HYDRA_DB_API_KEY=your-hydradb-api-key-here

# Anthropic — Claude for LLM narration
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Auth.js — session encryption secret (generate: openssl rand -base64 32)
AUTH_SECRET=your-auth-secret-here

# NextAuth — canonical URL of the deployed app (required in production)
# Set this to your Vercel deployment URL, e.g. https://hydrone.vercel.app
NEXTAUTH_URL=https://your-app.vercel.app
